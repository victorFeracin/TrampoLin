{
  "name": "trampolin-api",
  "version": "1.0.0",
  "description": "TrampoLin REST API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test:api": "mocha \"test/**/*.spec.js\" --timeout 30000",
    "test:api:report": "mocha \"test/**/*.spec.js\" --timeout 30000 --reporter mochawesome --reporter-option reportDir=test-results/mochawesome,reportFilename=index,quiet=true",
    "test:api:ci": "npm run test:api:report"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "chai": "^5.2.0",
    "mocha": "^10.8.2",
    "mochawesome": "^7.1.3",
    "supertest": "^7.1.1"
  }
}
